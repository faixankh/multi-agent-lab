AGENTOS_ENV=production
AGENTOS_API_KEY=replace-with-secret-from-secret-manager
AGENTOS_DATABASE_URL=sqlite:///./storage/agentos.db
AGENTOS_VECTOR_BACKEND=qdrant
AGENTOS_LLM_PROVIDER=enterprise_gateway
AGENTOS_OBJECT_STORAGE=gcs
AGENTOS_N8N_WEBHOOK_URL=https://n8n.example.com/webhook/agentos-execution
AGENTOS_ALLOW_EXTERNAL_HTTP=false
NEXT_PUBLIC_API_BASE_URL=https://agentos.example.com
